# =============================================================================
# OpenMAIC Environment Variables
# Copy this file to .env.local and fill in the values you need.
# All variables are optional — only configure the providers you want to use.
# You can also use server-providers.yml for configuration (see docs).
# =============================================================================

# --- Database (Prisma / PostgreSQL) ------------------------------------------
# Required for auth, credits, and subscriptions.
# On Hostinger VPS: create a Postgres DB and paste the connection string here.
# Format: postgresql://USER:PASSWORD@HOST:5432/DB_NAME
DATABASE_URL=postgresql://postgres:password@localhost:5432/openmaic

# After setting DATABASE_URL, run: pnpm prisma migrate deploy

# --- Authentication (NextAuth v5) --------------------------------------------
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET=
# Set to your production domain (e.g. https://yourdomain.com)
NEXTAUTH_URL=http://localhost:3000

# --- LLM Providers -----------------------------------------------------------
# Format: {PROVIDER}_API_KEY, {PROVIDER}_BASE_URL (optional), {PROVIDER}_MODELS (optional, comma-separated)

OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODELS=gpt-5-mini,gpt-5,gpt-5.4

ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODELS=

GOOGLE_API_KEY=
GOOGLE_BASE_URL=
GOOGLE_MODELS=

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=
DEEPSEEK_MODELS=

QWEN_API_KEY=
QWEN_BASE_URL=
QWEN_MODELS=

KIMI_API_KEY=
KIMI_BASE_URL=
KIMI_MODELS=

MINIMAX_API_KEY=
MINIMAX_BASE_URL=
MINIMAX_MODELS=

GLM_API_KEY=
GLM_BASE_URL=
GLM_MODELS=

SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=
SILICONFLOW_MODELS=

DOUBAO_API_KEY=
DOUBAO_BASE_URL=
DOUBAO_MODELS=

# --- TTS (Text-to-Speech) ----------------------------------------------------

TTS_OPENAI_API_KEY=
TTS_OPENAI_BASE_URL=

TTS_AZURE_API_KEY=
TTS_AZURE_BASE_URL=

TTS_GLM_API_KEY=
TTS_GLM_BASE_URL=

TTS_QWEN_API_KEY=
TTS_QWEN_BASE_URL=

# --- ASR (Automatic Speech Recognition) --------------------------------------

ASR_OPENAI_API_KEY=
ASR_OPENAI_BASE_URL=

ASR_QWEN_API_KEY=
ASR_QWEN_BASE_URL=

# --- PDF Processing -----------------------------------------------------------

PDF_UNPDF_API_KEY=
PDF_UNPDF_BASE_URL=

PDF_MINERU_API_KEY=
PDF_MINERU_BASE_URL=

# --- Image Generation ---------------------------------------------------------

IMAGE_SEEDREAM_API_KEY=
IMAGE_SEEDREAM_BASE_URL=

IMAGE_QWEN_IMAGE_API_KEY=
IMAGE_QWEN_IMAGE_BASE_URL=

IMAGE_NANO_BANANA_API_KEY=
IMAGE_NANO_BANANA_BASE_URL=

# --- Video Generation ---------------------------------------------------------

VIDEO_SEEDANCE_API_KEY=
VIDEO_SEEDANCE_BASE_URL=

VIDEO_KLING_API_KEY=
VIDEO_KLING_BASE_URL=

VIDEO_VEO_API_KEY=
VIDEO_VEO_BASE_URL=

VIDEO_SORA_API_KEY=
VIDEO_SORA_BASE_URL=

# --- Web Search ---------------------------------------------------------------

TAVILY_API_KEY=

# --- Proxy (optional) --------------------------------------------------------

# HTTP_PROXY=
# HTTPS_PROXY=

# --- Razorpay Payments --------------------------------------------------------
# Get these from your Razorpay Dashboard → Settings → API Keys
# https://dashboard.razorpay.com/app/keys

RAZORPAY_KEY_ID=rzp_live_...
RAZORPAY_KEY_SECRET=...
RAZORPAY_WEBHOOK_SECRET=...    # From Dashboard → Webhooks → Add New Webhook

# --- Misc ---------------------------------------------------------------------

# Default model for classroom generation routes (/api/generate/*, /api/generate-classroom)
DEFAULT_MODEL=openai:gpt-5-mini

# Default model for chat/interaction (/api/chat, /api/pbl/chat)
# Falls back to DEFAULT_MODEL if not set
DEFAULT_CHAT_MODEL=openai:gpt-5-mini

# Default model for verification tasks (/api/quiz/*, /api/interview/*)
# Falls back to DEFAULT_MODEL if not set
DEFAULT_VERIFICATION_MODEL=openai:gpt-5-mini

# Fast fallback model used when no model is specified and DEFAULT_MODEL is unset
# google:gemini-3-flash-preview is hardcoded as the final fallback in resolve-model.ts

# Default TTS provider and voice (used when client does not specify)
DEFAULT_TTS_PROVIDER=google-tts
DEFAULT_TTS_VOICE=hi-IN-Neural2-A

# LOG_LEVEL=info
# LOG_FORMAT=pretty
# LLM_THINKING_DISABLED=false
